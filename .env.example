OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-5-mini
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=pulse_db
GEMINI_API_KEY=replace-with-your-gemini-api-key
VEO_API_KEY=replace-with-your-veo-api-key
GOOGLE_CLOUD_PROJECT=replace-with-your-google-cloud-project
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_VIDEO_API_KEY=replace-with-your-vertex-video-api-key
PROMOTION_VEO_PROVIDER=vertex
PROMOTION_VEO_ENABLE_SECONDARY_BACKEND_FALLBACK=false
PROMOTION_VEO_ASPECT_RATIO=9:16
PROMOTION_VEO_VERTEX_STANDARD_MODEL=veo-3.1-fast-generate-001
PROMOTION_VEO_VERTEX_PRO_MODEL=veo-3.1-generate-001
PROMOTION_VEO_VERTEX_FAST_MODEL=veo-3.1-fast-generate-001
PROMOTION_VEO_VERTEX_STANDARD_RESOLUTION=720p
# Vertex AI video generation in this project expects ADC/service-account auth.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
